@inject NavigationManager Urihelper
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="StockMarket Dashboard Showcase app offers real-time data, analytics, insights, presenting key financial metrics, market trends in a user-friendly interface." />
    <title>Stock Market Dashboard - Syncfusion Blazor Showcase Demo</title>
    <base href="/" />
    <link href=@Urihelper.Uri rel="canonical" />
    <!-- Google Tag Manager -->
    <!-- Load GTM-P3WXFWCW immediately on page load  -->
    <script>
        (function (w, d, s, l, i) {
            w[l] = w[l] || []; w[l].push({
                'gtm.start':
                    new Date().getTime(), event: 'gtm.js'
            }); var f = d.getElementsByTagName(s)[0],
                j = d.createElement(s), dl = l != 'dataLayer' ? '&l=' + l : ''; j.async = true; j.src =
                    'https://www.googletagmanager.com/gtm.js?id=' + i + dl; f.parentNode.insertBefore(j, f);
        })(window, document, 'script', 'dataLayer', 'GTM-P3WXFWCW');
    </script>
    <!-- Load GTM-W8WD8WN on user interaction -->
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const events = ["mousemove", "scroll", "keydown", "touchstart"];
            function loadGTM() {
                events.forEach(event => document.removeEventListener(event, loadGTM));
                (function (w, d, s, l, i) {
                    w[l] = w[l] || []; w[l].push({
                        'gtm.start':
                            new Date().getTime(), event: 'gtm.js'
                    }); var f = d.getElementsByTagName(s)[0],
                        j = d.createElement(s), dl = l != 'dataLayer' ? '&l=' + l : ''; j.async = true; j.src =
                            'https://www.googletagmanager.com/gtm.js?id=' + i + dl; f.parentNode.insertBefore(j, f);
                })(window, document, 'script', 'dataLayer', 'GTM-W8WD8WN');
            }
            events.forEach(event => document.addEventListener(event, loadGTM, { once: true }));
        });
    </script>

    <ResourcePreloader />
    <link rel="stylesheet" href="@Assets["css/bootstrap/bootstrap.min.css"]" />
    <link rel="stylesheet" href="@Assets["StockMarket.styles.css"]" />
    <ImportMap />
    <link rel="shortcut icon" href="favicon.ico" />
    <link href="@Assets["css/site.css"]" rel="stylesheet" />
    <link href="@Assets["styles/BasicLayout.css"]" rel="stylesheet" />
    <link href="@Assets["css/ChartModule.css"]" rel="stylesheet" />
    <link href="@Assets["css/KeyStatsModule.css"]" rel="stylesheet" />
    <link href="@Assets["css/PerfomanceModule.css"]" rel="stylesheet" />
    <link href="@Assets["css/TechnicalModule.css"]" rel="stylesheet" />
    <link href="@Assets["css/WatchListModule.css"]" rel="stylesheet" />
    <script src="@Assets["./scripts/mobile-mode.js"]"></script>
    <link href="@Assets["_content/Syncfusion.Blazor/styles/fluent2.css"]" rel="stylesheet" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <!-- Google Tag Manager (noscript) -->
    <!--Page Load-->
    <noscript>
        <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-P3WXFWCW" height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>
    <!--Interaction-->
    <noscript>
        <iframe src="https://www.googletagmanager.com/ns.html?id=GTM-W8WD8WN" height="0" width="0" style="display:none;visibility:hidden"></iframe>
    </noscript>
    <!-- End Google Tag Manager (noscript) -->
    <div id="blazor-error-ui">
        <environment include="Staging,Production">
            An error has occurred. This application may no longer respond until reloaded.
        </environment>
        <environment include="Development">
            An unhandled exception has occurred. See browser dev tools for details.
        </environment>
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>
    <ReconnectModal />
    <script src="@Assets["_content/Syncfusion.Blazor/scripts/syncfusion-blazor.min.js"]" type="text/javascript"></script>
    <script src="@Assets["_framework/blazor.server.js"]"></script>
</body>

</html>
